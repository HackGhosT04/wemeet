# Example environment variables for WeMeet
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_CONFIG_JSON={"type": "service_account", ... }  # JSON string of service account credentials
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
SESSION_SECRET_KEY=super-secret-session-key

# This template uses STUN only (Google STUN). TURN entries removed to avoid costs.
# Optionally enable strict https-only cookies in production
USE_HTTPS=true
